# PODProfit — environment variables template
# Copy to .env.local (gitignored) and fill in actual values.
# Per CEO slim-down decree (2026-05-03): use FREE tier wherever possible.

# ---------- Public (exposed to browser) ----------
NEXT_PUBLIC_SITE_URL="https://getpodprofit.com"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Stripe publishable (browser-safe). Test Mode keys ship in .env.local; Live keys
# are added to Vercel Environment Variables only after Stripe Live re-approval.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Cloudflare Web Analytics (free, replaces Plausible $9/mo until traffic > 1K/mo)
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=""
# measurement-spec-v1 §4.1 alias used by `src/lib/analytics/cloudflare.ts`.
# When unset the helper is a no-op (custom events drop silently — see file).
NEXT_PUBLIC_CF_WA_TOKEN=""

# PostHog (free tier, cookieless mode — see lib/analytics)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ---------- Server-only secrets (never commit) ----------
SUPABASE_SERVICE_ROLE_KEY=""

# Stripe (Test Mode keys until Stripe Live re-approval; Live keys swapped via
# Vercel Environment Variables — code does not need to change between modes).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Test/Live Price IDs are set per environment. The app resolves prices by
# `lookup_key` first (test/prod-mode independent) and falls back to these
# ids for environments without lookup_keys configured.
STRIPE_PRICE_ID_MONTHLY=""
STRIPE_PRICE_ID_ANNUAL=""
STRIPE_PRICE_ID_LIFETIME=""

# Printful API (read-only catalog, see secrets/printful.env)
PRINTFUL_API_TOKEN=""

# Printify API (read-only catalog, see secrets/printify.env)
PRINTIFY_API_TOKEN=""

# Buttondown (free up to 100 subs)
BUTTONDOWN_API_KEY=""

# AIO tracking (Anthropic / OpenAI API for monthly LLM citation checks)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Cron secret (for protecting GitHub Actions → /api/cron/* endpoints)
CRON_SECRET=""

# Admin surface (Basic auth gate at the Edge middleware level — see
# `src/middleware.ts`). Both required; missing either disables the surface.
# Production values are set in Vercel Environment Variables only.
ADMIN_USER=""
ADMIN_PASS=""
